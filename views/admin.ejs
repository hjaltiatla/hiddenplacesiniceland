<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-800"><%= t('admin_title') %></h1>
  <a href="/<%= lang %>" class="text-sm text-blue-600 hover:underline"><%= t('admin_back') %></a>
</div>

<% if (error) { %>
  <div class="bg-red-50 border border-red-200 text-red-700 rounded-xl px-4 py-3 mb-6 text-sm">
    ⚠️ <%= error %>
  </div>
<% } %>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

  <!-- Add place form -->
  <div class="bg-white rounded-2xl shadow p-6">
    <h2 class="text-lg font-semibold text-gray-700 mb-5 border-b pb-2"><%= t('admin_add_heading') %></h2>

    <form method="POST" action="/<%= lang %>/admin/add" class="space-y-4">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

        <div class="sm:col-span-2">
          <label class="block text-xs font-semibold text-gray-600 mb-1"><%= t('admin_field_name') %></label>
          <input type="text" name="name" required placeholder="<%= t('admin_placeholder_name') %>"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-400 outline-none">
        </div>

        <div>
          <label class="block text-xs font-semibold text-gray-600 mb-1"><%= t('admin_field_lat') %></label>
          <input type="number" name="latitude" step="0.0001" min="63" max="67" required
            placeholder="<%= t('admin_placeholder_lat') %>"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-400 outline-none">
        </div>

        <div>
          <label class="block text-xs font-semibold text-gray-600 mb-1"><%= t('admin_field_lon') %></label>
          <input type="number" name="longitude" step="0.0001" min="-25" max="-13" required
            placeholder="<%= t('admin_placeholder_lon') %>"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-400 outline-none">
        </div>

        <div>
          <label class="block text-xs font-semibold text-gray-600 mb-1"><%= t('admin_field_category') %></label>
          <select name="category" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-400 outline-none">
            <option value=""><%= t('admin_select_category') %></option>
            <% Object.entries(categories).forEach(([key, label]) => { %>
              <option value="<%= key %>"><%= label %></option>
            <% }) %>
          </select>
        </div>

        <div>
          <label class="block text-xs font-semibold text-gray-600 mb-1"><%= t('admin_field_difficulty') %></label>
          <select name="difficulty" required class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-400 outline-none">
            <option value=""><%= t('admin_select_difficulty') %></option>
            <% Object.entries(difficulties).forEach(([key, label]) => { %>
              <option value="<%= key %>"><%= label %></option>
            <% }) %>
          </select>
        </div>

        <div>
          <label class="block text-xs font-semibold text-gray-600 mb-1"><%= t('admin_field_region') %></label>
          <input type="text" name="region" placeholder="<%= t('admin_placeholder_region') %>"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-400 outline-none">
        </div>

        <div>
          <label class="block text-xs font-semibold text-gray-600 mb-1"><%= t('admin_field_season') %></label>
          <input type="text" name="best_season" placeholder="<%= t('admin_placeholder_season') %>"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-400 outline-none">
        </div>

        <div class="sm:col-span-2">
          <label class="block text-xs font-semibold text-gray-600 mb-1"><%= t('admin_field_photo') %></label>
          <input type="url" name="photo_url" placeholder="https://..."
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-400 outline-none">
        </div>

        <div class="sm:col-span-2">
          <label class="block text-xs font-semibold text-gray-600 mb-1">🖼️ <%= t('admin_field_images') %></label>
          <textarea name="images" rows="3"
            placeholder="<%= t('admin_placeholder_images') %>"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-400 outline-none resize-none"></textarea>
          <p class="text-xs text-gray-400 mt-1"><%= t('admin_images_hint') %></p>
        </div>

        <div class="sm:col-span-2">
          <label class="block text-xs font-semibold text-gray-600 mb-1"><%= t('admin_field_maps') %></label>
          <input type="url" name="google_maps_url" placeholder="https://maps.google.com/?q=..."
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-400 outline-none">
        </div>

        <div>
          <label class="block text-xs font-semibold text-gray-600 mb-1">🚗 <%= t('admin_field_drive_time') %></label>
          <input type="text" name="drive_time_from_reykjavik" placeholder="<%= t('admin_placeholder_drive_time') %>"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-400 outline-none">
        </div>

        <div>
          <label class="block text-xs font-semibold text-gray-600 mb-1">🅿️ <%= t('admin_field_parking') %></label>
          <input type="text" name="parking_info" placeholder="<%= t('admin_placeholder_parking') %>"
            class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-400 outline-none">
        </div>

        <!-- 4 description fields -->
        <% [
          { field: 'description_en', labelKey: 'admin_field_desc_en', flag: '🇬🇧' },
          { field: 'description_es', labelKey: 'admin_field_desc_es', flag: '🇪🇸' },
          { field: 'description_de', labelKey: 'admin_field_desc_de', flag: '🇩🇪' },
          { field: 'description_zh', labelKey: 'admin_field_desc_zh', flag: '🇨🇳' }
        ].forEach(({ field, labelKey, flag }) => { %>
          <div class="sm:col-span-2">
            <label class="block text-xs font-semibold text-gray-600 mb-1">
              <%= flag %> <%= t(labelKey) %>
            </label>
            <textarea name="<%= field %>" rows="3"
              placeholder="<%= t('admin_field_desc_placeholder') %>"
              class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-400 outline-none resize-none"></textarea>
          </div>
        <% }) %>
      </div>

      <button type="submit"
        class="w-full bg-iceland-blue text-white py-2.5 rounded-xl font-semibold hover:bg-blue-800 transition-colors">
        <%= t('admin_btn_add') %>
      </button>
    </form>
  </div>

  <!-- Existing places list -->
  <div class="bg-white rounded-2xl shadow p-6">
    <h2 class="text-lg font-semibold text-gray-700 mb-5 border-b pb-2">
      <%= t('admin_list_heading') %> (<%= places.length %>)
    </h2>

    <% if (places.length === 0) { %>
      <p class="text-gray-400 text-sm text-center py-8"><%= t('admin_empty') %></p>
    <% } else { %>
      <div class="space-y-3 max-h-[600px] overflow-y-auto pr-1">
        <% places.forEach(place => { %>
          <div class="flex items-center justify-between bg-gray-50 rounded-xl px-4 py-3 gap-2">
            <div class="min-w-0">
              <a href="/<%= lang %>/places/<%= place.id %>"
                class="font-medium text-gray-800 text-sm hover:text-blue-600 truncate block">
                <%= place.name %>
              </a>
              <p class="text-xs text-gray-400 mt-0.5">
                <%= place.region || '–' %> &bull;
                <span class="category-<%= place.category %> px-1.5 py-0.5 rounded-full text-xs font-medium">
                  <%= categories[place.category] || place.category %>
                </span>
              </p>
            </div>
            <form method="POST" action="/<%= lang %>/admin/delete/<%= place.id %>"
              onsubmit="return confirm('<%= t('admin_confirm_delete') %>')">
              <button type="submit" class="text-red-400 hover:text-red-600 text-sm font-medium shrink-0 transition-colors">
                <%= t('admin_btn_delete') %>
              </button>
            </form>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

</div>

<script>
  const params = new URLSearchParams(window.location.search);
  if (params.get('success') === '1') showToast('<%= t('admin_toast_added') %>');
  else if (params.get('success') === '2') showToast('<%= t('admin_toast_deleted') %>');

  function showToast(msg) {
    const toast = document.createElement('div');
    toast.textContent = msg;
    toast.style.cssText = 'position:fixed;bottom:24px;right:24px;background:#1a1a2e;color:white;padding:12px 20px;border-radius:12px;font-size:14px;z-index:9999;box-shadow:0 4px 20px rgba(0,0,0,0.3);';
    document.body.appendChild(toast);
    setTimeout(() => toast.remove(), 3500);
    history.replaceState(null, '', '/<%= lang %>/admin');
  }
</script>
