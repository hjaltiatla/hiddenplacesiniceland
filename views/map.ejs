<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<style>
  .leaflet-popup-content { margin: 0; padding: 0; }
  .leaflet-popup-content-wrapper { padding: 0; overflow: hidden; border-radius: 14px; box-shadow: 0 8px 30px rgba(0,0,0,0.18); }
  .leaflet-popup-tip-container { margin-top: -1px; }
</style>

<h1 class="text-2xl font-bold text-gray-800 mb-1"><%= t('map_title') %></h1>
<p class="text-gray-500 mb-4 text-sm"><%= t('map_subtitle') %></p>

<!-- Filters -->
<div class="bg-white rounded-2xl shadow p-4 mb-4 flex flex-wrap gap-3 items-end">
  <div>
    <label class="block text-xs font-semibold text-gray-600 mb-1"><%= t('label_category') %></label>
    <select id="filter-category" class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-400 outline-none">
      <option value=""><%= t('all_categories') %></option>
      <% Object.entries(categories).forEach(([key, label]) => { %>
        <option value="<%= key %>"><%= label %></option>
      <% }) %>
    </select>
  </div>

  <div>
    <label class="block text-xs font-semibold text-gray-600 mb-1"><%= t('label_difficulty') %></label>
    <select id="filter-difficulty" class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-400 outline-none">
      <option value=""><%= t('all_difficulties') %></option>
      <% Object.entries(difficulties).forEach(([key, label]) => { %>
        <option value="<%= key %>"><%= label %></option>
      <% }) %>
    </select>
  </div>

  <div>
    <label class="block text-xs font-semibold text-gray-600 mb-1"><%= t('label_region') %></label>
    <select id="filter-region" class="border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-400 outline-none">
      <option value=""><%= t('all_regions') %></option>
      <% regions.forEach(r => { %>
        <option value="<%= r %>"><%= r %></option>
      <% }) %>
    </select>
  </div>

  <p id="filter-count" class="text-sm text-gray-500 ml-auto self-center"></p>
</div>

<!-- Map -->
<div id="map" class="rounded-2xl shadow overflow-hidden" style="height: 70vh; min-height: 400px;"></div>

<!-- Legend -->
<div class="mt-4 flex flex-wrap gap-3 text-sm">
  <span class="px-3 py-1 rounded-full category-waterfall font-medium">💧 <%= t('cat_waterfall') %></span>
  <span class="px-3 py-1 rounded-full category-canyon font-medium">🪨 <%= t('cat_canyon') %></span>
  <span class="px-3 py-1 rounded-full category-hike font-medium">🥾 <%= t('cat_hike') %></span>
  <span class="px-3 py-1 rounded-full category-hot_spring font-medium">♨️ <%= t('cat_hot_spring') %></span>
  <span class="px-3 py-1 rounded-full category-viewpoint font-medium">🔭 <%= t('cat_viewpoint') %></span>
  <span class="px-3 py-1 rounded-full category-beach font-medium">🏖️ <%= t('cat_beach') %></span>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
  const LANG = '<%= lang %>';
  const LABELS = <%- JSON.stringify({
    cats: {
      waterfall:  t('cat_waterfall'),
      canyon:     t('cat_canyon'),
      hike:       t('cat_hike'),
      hot_spring: t('cat_hot_spring'),
      viewpoint:  t('cat_viewpoint'),
      beach:      t('cat_beach')
    },
    diffs: {
      easy:   t('diff_easy'),
      medium: t('diff_medium'),
      hard:   t('diff_hard')
    },
    view_details:  t('map_view_details'),
    results_found: t('results_found')
  }) %>;

  const PLACES = <%- JSON.stringify(places) %>;

  const CAT_ICONS = {
    waterfall: '💧', canyon: '🪨', hike: '🥾',
    hot_spring: '♨️', viewpoint: '🔭', beach: '🏖️'
  };
  const CAT_STYLE = {
    waterfall:  'background:#dbeafe;color:#1e40af',
    canyon:     'background:#ede9fe;color:#5b21b6',
    hike:       'background:#dcfce7;color:#166534',
    hot_spring: 'background:#ffedd5;color:#9a3412',
    viewpoint:  'background:#f0fdf4;color:#14532d',
    beach:      'background:#ecfeff;color:#155e75'
  };
  const DIFF_STYLE = {
    easy:   'background:#d1fae5;color:#065f46',
    medium: 'background:#fef3c7;color:#92400e',
    hard:   'background:#fee2e2;color:#991b1b'
  };

  const map = L.map('map').setView([64.9631, -19.0208], 6);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© <a href="https://openstreetmap.org">OpenStreetMap</a> contributors',
    maxZoom: 18
  }).addTo(map);

  const allMarkers = PLACES.map(place => {
    const icon = L.divIcon({
      html: `<div style="background:#003F87;color:white;border-radius:50%;width:36px;height:36px;display:flex;align-items:center;justify-content:center;font-size:18px;box-shadow:0 2px 8px rgba(0,0,0,0.3);border:2px solid white;">${CAT_ICONS[place.category] || '📍'}</div>`,
      className: '',
      iconSize: [36, 36],
      iconAnchor: [18, 18],
      popupAnchor: [0, -22]
    });

    const imgBlock = `<img src="${place.imageUrl}" style="width:100%;height:120px;object-fit:cover;display:block;" onerror="this.src='/images/default-place.jpg'">`;

    const popupHtml = `
      <div style="width:230px;font-family:system-ui,sans-serif;overflow:hidden;">
        ${imgBlock}
        <div style="padding:10px 12px 12px;">
          <strong style="font-size:14px;display:block;margin-bottom:6px;">${place.name}</strong>
          <div style="display:flex;gap:4px;flex-wrap:wrap;margin-bottom:8px;">
            <span style="font-size:11px;font-weight:600;padding:2px 8px;border-radius:99px;${CAT_STYLE[place.category] || ''}">${LABELS.cats[place.category] || place.category}</span>
            <span style="font-size:11px;font-weight:600;padding:2px 8px;border-radius:99px;${DIFF_STYLE[place.difficulty] || 'background:#f3f4f6;color:#374151'}">${LABELS.diffs[place.difficulty] || place.difficulty}</span>
          </div>
          <a href="/${LANG}/places/${place.id}" style="color:#003F87;font-weight:600;font-size:13px;text-decoration:none;">
            ${LABELS.view_details}
          </a>
        </div>
      </div>
    `;

    const marker = L.marker([place.latitude, place.longitude], { icon })
      .bindPopup(popupHtml, { maxWidth: 230 });

    return { marker, place };
  });

  function applyFilters() {
    const cat    = document.getElementById('filter-category').value;
    const diff   = document.getElementById('filter-difficulty').value;
    const region = document.getElementById('filter-region').value;
    let count = 0;

    allMarkers.forEach(({ marker, place }) => {
      const visible =
        (!cat    || place.category   === cat)  &&
        (!diff   || place.difficulty === diff) &&
        (!region || place.region     === region);

      if (visible) {
        if (!map.hasLayer(marker)) marker.addTo(map);
        count++;
      } else {
        if (map.hasLayer(marker)) map.removeLayer(marker);
      }
    });

    document.getElementById('filter-count').textContent =
      `${count} ${LABELS.results_found}`;
  }

  ['filter-category', 'filter-difficulty', 'filter-region'].forEach(id =>
    document.getElementById(id).addEventListener('change', applyFilters)
  );

  applyFilters();
</script>
