<%
  const difficultyClass = { easy: 'badge-easy', medium: 'badge-medium', hard: 'badge-hard' };
  const description = place['description_' + lang] || place.description_en || '';
%>

<div class="mb-6">
  <a href="/<%= lang %>" class="text-blue-600 hover:underline text-sm flex items-center gap-1">
    <%= t('back_to_list') %>
  </a>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

  <!-- Left: main content -->
  <div class="lg:col-span-2 space-y-6">

    <!-- Hero photo + gallery -->
    <div class="rounded-2xl overflow-hidden shadow bg-gray-200">
      <div class="h-72 bg-gray-200">
        <img id="main-img" src="<%= allImages[0] %>" alt="<%= place.name %>"
          class="w-full h-full object-cover"
          onerror="this.src='/images/default-place.jpg'">
      </div>

      <% if (allImages.length > 1) { %>
        <div class="flex gap-2 p-2 bg-black/20 overflow-x-auto">
          <% allImages.forEach((url, i) => { %>
            <img src="<%= url %>" alt=""
              class="h-16 w-24 object-cover rounded-lg cursor-pointer shrink-0 transition-all duration-150 <%= i === 0 ? 'ring-2 ring-white opacity-100' : 'opacity-50 hover:opacity-80' %>"
              onclick="setMainImage(this, '<%= url %>')"
              onerror="this.style.display='none'">
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- Title + badges -->
    <div>
      <div class="flex flex-wrap items-center gap-2 mb-2">
        <span class="text-sm font-semibold px-3 py-1 rounded-full category-<%= place.category %>">
          <%= categories[place.category] || place.category %>
        </span>
        <span class="text-sm font-semibold px-3 py-1 rounded-full <%= difficultyClass[place.difficulty] || 'bg-gray-100 text-gray-600' %>">
          <%= difficulties[place.difficulty] || place.difficulty %>
        </span>
      </div>
      <h1 class="text-3xl font-bold text-gray-800"><%= place.name %></h1>
      <p class="text-gray-500 mt-1 flex items-center gap-1">📍 <%= place.region || 'Iceland' %></p>
    </div>

    <!-- Description -->
    <div class="bg-white rounded-2xl shadow p-6">
      <h2 class="font-semibold text-gray-700 mb-3 text-lg"><%= t('section_description') %></h2>
      <p class="text-gray-600 leading-relaxed whitespace-pre-line">
        <%= description || t('no_description') %>
      </p>
    </div>

    <!-- Mini map -->
    <div class="bg-white rounded-2xl shadow p-6">
      <h2 class="font-semibold text-gray-700 mb-3 text-lg"><%= t('section_location') %></h2>
      <div id="mini-map" class="h-64 rounded-xl overflow-hidden z-0"></div>
    </div>
  </div>

  <!-- Right: sidebar -->
  <div class="space-y-4">
    <div class="bg-white rounded-2xl shadow p-5 space-y-4">
      <h2 class="font-semibold text-gray-700 text-lg border-b pb-2"><%= t('section_info') %></h2>

      <div>
        <p class="text-xs text-gray-400 uppercase tracking-wide font-semibold"><%= t('label_region_detail') %></p>
        <p class="text-gray-700 mt-0.5">📍 <%= place.region || '–' %></p>
      </div>
      <div>
        <p class="text-xs text-gray-400 uppercase tracking-wide font-semibold"><%= t('label_category_detail') %></p>
        <p class="text-gray-700 mt-0.5"><%= categories[place.category] || place.category %></p>
      </div>
      <div>
        <p class="text-xs text-gray-400 uppercase tracking-wide font-semibold"><%= t('label_difficulty_detail') %></p>
        <p class="mt-0.5">
          <span class="text-sm font-semibold px-2 py-1 rounded-full <%= difficultyClass[place.difficulty] || '' %>">
            <%= difficulties[place.difficulty] || place.difficulty %>
          </span>
        </p>
      </div>
      <% if (place.best_season) { %>
        <div>
          <p class="text-xs text-gray-400 uppercase tracking-wide font-semibold"><%= t('label_best_season') %></p>
          <p class="text-gray-700 mt-0.5">🗓 <%= place.best_season %></p>
        </div>
      <% } %>
      <% if (place.drive_time_from_reykjavik) { %>
        <div>
          <p class="text-xs text-gray-400 uppercase tracking-wide font-semibold"><%= t('label_drive_time') %></p>
          <p class="text-gray-700 mt-0.5">🚗 <%= place.drive_time_from_reykjavik %></p>
        </div>
      <% } %>
      <% if (place.parking_info) { %>
        <div>
          <p class="text-xs text-gray-400 uppercase tracking-wide font-semibold"><%= t('label_parking_info') %></p>
          <p class="text-gray-700 mt-0.5">🅿️ <%= place.parking_info %></p>
        </div>
      <% } %>
      <div>
        <p class="text-xs text-gray-400 uppercase tracking-wide font-semibold"><%= t('label_coordinates') %></p>
        <p class="text-gray-700 mt-0.5 font-mono text-sm">
          <%= place.latitude.toFixed(4) %>, <%= place.longitude.toFixed(4) %>
        </p>
      </div>
    </div>

    <% if (place.google_maps_url) { %>
      <a href="<%= place.google_maps_url %>" target="_blank" rel="noopener noreferrer"
        class="flex items-center justify-center gap-2 w-full bg-iceland-blue text-white rounded-2xl py-3 font-semibold hover:bg-blue-800 transition-colors">
        <%= t('btn_google_maps') %>
      </a>
    <% } %>

    <a href="/<%= lang %>/map"
      class="flex items-center justify-center gap-2 w-full bg-gray-100 text-gray-700 rounded-2xl py-3 font-semibold hover:bg-gray-200 transition-colors">
      <%= t('btn_view_map') %>
    </a>
  </div>
</div>

<% if (nearby.length > 0) { %>
<div class="mt-10">
  <h2 class="text-xl font-bold text-gray-800 mb-4"><%= t('nearby_title') %></h2>
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
    <% nearby.forEach(p => { %>
      <a href="/<%= lang %>/places/<%= p.id %>" class="bg-white rounded-2xl shadow overflow-hidden card-hover block">
        <div class="relative h-32 bg-gray-200 overflow-hidden">
          <img src="<%= p.imageUrl %>" alt="<%= p.name %>" class="w-full h-full object-cover"
            onerror="this.src='/images/default-place.jpg'">
          <span class="absolute top-2 right-2 bg-white/90 backdrop-blur-sm text-gray-800 text-xs font-bold px-2 py-0.5 rounded-full shadow">
            <%= p.distance %> km
          </span>
        </div>
        <div class="p-3">
          <p class="font-semibold text-gray-800 text-sm truncate"><%= p.name %></p>
          <span class="mt-1 inline-block text-xs font-semibold px-2 py-0.5 rounded-full category-<%= p.category %>">
            <%= categories[p.category] || p.category %>
          </span>
        </div>
      </a>
    <% }) %>
  </div>
</div>
<% } %>

<script>
  function setMainImage(thumb, url) {
    document.getElementById('main-img').src = url;
    document.querySelectorAll('[onclick^="setMainImage"]').forEach(t => {
      t.classList.remove('ring-2', 'ring-white', 'opacity-100');
      t.classList.add('opacity-50');
    });
    thumb.classList.add('ring-2', 'ring-white', 'opacity-100');
    thumb.classList.remove('opacity-50');
  }
</script>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
  const map = L.map('mini-map').setView([<%= place.latitude %>, <%= place.longitude %>], 11);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© OpenStreetMap contributors'
  }).addTo(map);
  L.marker([<%= place.latitude %>, <%= place.longitude %>])
    .addTo(map)
    .bindPopup('<strong><%= place.name.replace(/'/g, "\\'") %></strong>')
    .openPopup();
</script>
